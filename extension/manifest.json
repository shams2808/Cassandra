{
  "manifest_version": 3,
  "name": "Cassandra PR Reviewer",
  "version": "1.0.0",
  "description": "Context-Aware PR Reviewer extension (Track A)",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://github.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*/pull/*"
      ],
      "js": [
        "dom_extractor.js",
        "renderer.js",
        "content_script.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ]
}
